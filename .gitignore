# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.venv/
venv/
.pytest_cache/
.ruff_cache/
build/
dist/

# mkdocs (sitio generado, se construye desde docs/ + mkdocs.yml)
site/

# Runs / experimentos (se generan al entrenar, no se versionan)
runs/
experiments/*.log

# Unity (proyecto en unity/, se añadirá en fases posteriores)
unity/**/Library/
unity/**/Temp/
unity/**/Obj/
unity/**/Build/
unity/**/Builds/
unity/**/Logs/
unity/**/UserSettings/
unity/**/.vs/
unity/**/*.csproj
unity/**/*.sln
unity/**/*.user

# Binarios compilados de los ejemplos (p. ej. examples/csharp_bridge/bridge.exe):
# se compilan on-demand desde el .cs, no se versionan.
examples/**/*.exe
examples/**/*.dll
examples/**/*.pdb

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
